#!/bin/sh
#
# zopen-publish script for publishing zopen community ports to GitHub Releases and/or Pulp
#

setupMyself() {
  ME=$(basename "$0")
  MYDIR="$(cd "$(dirname "$0")" > /dev/null 2>&1 && pwd -P)"
  INCDIR="${MYDIR}/../include"
  if ! [ -d "${INCDIR}" ] || ! [ -f "${INCDIR}/common.sh" ]; then
    echo "Internal Error. Unable to find common.sh file to source." >&2
    exit 8
  fi
  . "${INCDIR}/common.sh"
}
setupMyself

#
# IMPORTANT:
# Ensure verbose output never contaminates command substitution stdout.
# Functions like createGitHubRelease return machine-readable values on stdout.
#
printVerbose() {
  if [ "${verbose:-false}" = true ]; then
    echo "VERBOSE: $*" >&2
  fi
}

printSyntax()
{
  echo "${ME} - Publish zopen package release to GitHub and/or Pulp."
  echo ""
  echo "Usage: ${ME} [OPTION] -p PAX_FILE -m METADATA_FILE -g TAG"
  echo "       ${ME} [OPTION] --whl WHL_FILE --pulp-url URL"
  echo ""
  echo "Options:"
  echo "  -h, --help                print this help"
  echo "  -v, --verbose             run in verbose mode."
  echo "  -f, --force               Force overwrite release if tag exists."
  echo "  -p, --pax-file PAX_FILE   Path to the pax.Z file required for GitHub publish"
  echo "  -m, --metadata-file FILE  Path to the metadata.json file required for GitHub publish"
  echo "  -g, --tag TAG             Tag name for the release, e.g. DEV_mypackage_12345"
  echo "  -r, --repo REPO_URL       GitHub repository URL, optional, overrides metadata.json"
  echo "  -d, --description TEXT    Description for the GitHub release"
  echo "  -b, --build-line LINE     Build line: DEV or STABLE"
  echo "  -t, --github-token TOKEN  GitHub token, or set GITHUB_TOKEN"
  echo "  -o, --github-org ORG      GitHub Organization, default: zopencommunity"
  echo "  -l, --latest              Mark release as Latest / non-prerelease"
  echo "  --pulp                    Push RPM artifacts to Pulp repository"
  echo "  --pulp-repo REPO          Pulp repository name, default: zopen-stable or zopen-dev"
  echo "  -w, --whl WHL_FILE        Path to a Python wheel file to publish to Pulp PyPI"
  echo "  --pulp-url URL            Pulp PyPI repository URL"
  echo "  --pulp-user USER          Pulp username, or set PULP_USER"
  echo "  --pulp-password PASS      Pulp password, or set PULP_PASSWORD"
  echo "  --version                 print version"
  echo ""
  echo "Environment Variables:"
  echo "  GITHUB_TOKEN              GitHub Personal Access Token"
  echo "  PULP_URL                  Pulp PyPI repository URL"
  echo "  PULP_USER                 Pulp username"
  echo "  PULP_PASSWORD             Pulp password"
  echo ""
  echo "Examples:"
  echo "  zopen-publish -f -p install/mypackage.zos.pax.Z -m metadata.json -g DEV_mypackage_12345 -t <token>"
  echo "  zopen-publish --whl dist/mypackage-1.0-py3-none-any.whl --pulp-url http://host:8080/pypi/zopen/"
  echo "  zopen-publish -f -p install/mypackage.zos.pax.Z -m metadata.json -g TAG -t <token> --pulp"
}

checkDependencies() {
  if ! command -v curl > /dev/null 2>&1; then
    printError "Error: curl command not found. Please install it."
    return 1
  fi

  if ! command -v jq > /dev/null 2>&1; then
    printError "Error: jq command not found. Please install it."
    return 1
  fi

  if [ "$PUSH_TO_PULP" = true ]; then
    if ! command -v pulp > /dev/null 2>&1; then
      printError "Error: pulp command not found. Please install it to use --pulp option."
      return 1
    fi
  fi

  return 0
}

processOptions() {
  args=$*
  verbose=false
  MAKE_LATEST_RELEASE=false
  RELEASE_TAG_OPT=""
  FORCE_OVERWRITE=false
  PUSH_TO_PULP=false
  CUSTOM_PULP_REPO=""

  if [ $# -eq 0 ]; then
    printError "No options specified."
    printSyntax
    exit 1
  fi

  while [ $# -gt 0 ]; do
    case "$1" in
      "-h" | "--help")
        printSyntax
        exit 0
        ;;

      "-v" | "--verbose")
        verbose=true
        ;;

      "-f" | "--force")
        FORCE_OVERWRITE=true
        ;;

      "-p" | "--pax-file")
        PAX_FILE="$2"
        shift
        ;;

      "-m" | "--metadata-file")
        METADATA_FILE="$2"
        shift
        ;;

      "-r" | "--repo")
        PORT_GITHUB_REPO_OPT="$2"
        shift
        ;;

      "-d" | "--description")
        PORT_DESCRIPTION_OPT="$2"
        shift
        ;;

      "-b" | "--build-line")
        BUILD_LINE_OPT="$2"
        shift
        ;;

      "-t" | "--github-token")
        GITHUB_TOKEN_OPT="$2"
        shift
        ;;

      "-o" | "--github-org")
        GITHUB_ORGANIZATION="$2"
        shift
        ;;

      "-l" | "--latest")
        MAKE_LATEST_RELEASE=true
        ;;

      "-g" | "--tag")
        RELEASE_TAG_OPT="$2"
        shift
        ;;

      "--pulp")
        PUSH_TO_PULP=true
        ;;

      "--pulp-repo")
        CUSTOM_PULP_REPO="$2"
        PUSH_TO_PULP=true
        shift
        ;;

      "-w" | "--whl")
        WHL_FILE="$2"
        shift
        ;;

      "--pulp-url")
        PULP_URL_OPT="$2"
        shift
        ;;

      "--pulp-user")
        PULP_USER_OPT="$2"
        shift
        ;;

      "--pulp-password")
        PULP_PASSWORD_OPT="$2"
        shift
        ;;

      "--version")
        zopen-version "${ME}"
        exit 0
        ;;

      -*)
        printError "Unknown option '$1'"
        printSyntax
        exit 1
        ;;

      *)
        printError "Unexpected argument '$1'"
        printSyntax
        exit 1
        ;;
    esac
    shift
  done

  PUBLISH_GITHUB=false
  PUBLISH_PULP=false

  if [ -n "$PAX_FILE" ] || [ -n "$METADATA_FILE" ] || [ -n "$RELEASE_TAG_OPT" ]; then
    PUBLISH_GITHUB=true
  fi

  if [ -n "$WHL_FILE" ] || [ -n "$PULP_URL_OPT" ] || [ -n "$PULP_URL" ]; then
    PUBLISH_PULP=true
  fi

  if [ "$PUSH_TO_PULP" = true ]; then
    PUBLISH_GITHUB=true
  fi

  if ! ${PUBLISH_GITHUB} && ! ${PUBLISH_PULP}; then
    printError "No publish target specified. Provide -p/-m/-g for GitHub, --pulp for RPM Pulp, or --whl/--pulp-url for Pulp PyPI."
    printSyntax
    exit 1
  fi

  if ${PUBLISH_GITHUB}; then
    if [ -z "$PAX_FILE" ] || [ -z "$METADATA_FILE" ] || [ -z "$RELEASE_TAG_OPT" ]; then
      printError "GitHub publish requires: -p PAX_FILE, -m METADATA_FILE, and -g TAG."
      printSyntax
      exit 1
    fi

    if [ ! -f "$PAX_FILE" ]; then
      printError "PAX file not found: $PAX_FILE"
      exit 1
    fi

    if [ ! -f "$METADATA_FILE" ]; then
      printError "Metadata file not found: $METADATA_FILE"
      exit 1
    fi

    if [ -z "$GITHUB_TOKEN_OPT" ] && [ -z "$GITHUB_TOKEN" ]; then
      printError "GitHub token is required. Please provide it via --github-token or GITHUB_TOKEN."
      printSyntax
      exit 1
    fi

    if [ -n "$GITHUB_TOKEN_OPT" ]; then
      export GITHUB_TOKEN="$GITHUB_TOKEN_OPT"
    fi

    if [ -z "$GITHUB_ORGANIZATION" ]; then
      export GITHUB_ORGANIZATION="zopencommunity"
    fi
  fi

  if ${PUBLISH_PULP}; then
    if [ -z "$WHL_FILE" ]; then
      printError "Pulp PyPI publish requires: --whl WHL_FILE"
      exit 1
    fi

    if [ ! -f "$WHL_FILE" ]; then
      printError "Wheel file not found: $WHL_FILE"
      exit 1
    fi

    if [ -n "$PULP_URL_OPT" ]; then
      PULP_URL="$PULP_URL_OPT"
    fi

    if [ -z "$PULP_URL" ]; then
      printError "Pulp URL is required. Please provide it via --pulp-url or PULP_URL."
      exit 1
    fi

    if [ -n "$PULP_USER_OPT" ]; then
      PULP_USER="$PULP_USER_OPT"
    fi
    : "${PULP_USER:=admin}"

    if [ -n "$PULP_PASSWORD_OPT" ]; then
      PULP_PASSWORD="$PULP_PASSWORD_OPT"
    fi

    if [ -z "$PULP_PASSWORD" ]; then
      printError "Pulp password is required. Please provide it via --pulp-password or PULP_PASSWORD."
      exit 1
    fi
  fi

  export FORCE_OVERWRITE
  export PUSH_TO_PULP
  export CUSTOM_PULP_REPO
}

json_escape() {
  printf '%s' "$1" | jq -Rs .
}

validateReleaseId() {
  release_id="$1"

  case "$release_id" in
    ''|*[!0-9]*)
      printError "Invalid GitHub release ID: [$release_id]"
      return 1
      ;;
  esac

  return 0
}

createGitHubRelease() {
  tag="$1"
  name="$2"
  description="$3"
  make_latest_release="$4"

  printVerbose "Attempting to create release with tag: $tag, name: $name, latest: ${make_latest_release}"
  printVerbose "Creating GitHub release tag: $tag, name: $name, latest: ${make_latest_release}"

  api_url="https://api.github.com/repos/${GITHUB_ORGANIZATION}/${GITHUB_REPO}/releases"

  prerelease_value="true"
  if [ "${make_latest_release}" = "true" ]; then
    prerelease_value="false"
  fi

  tag_json=$(json_escape "$tag")
  name_json=$(json_escape "$name")
  body_json=$(json_escape "$description")

  payload=$(printf '{"tag_name": %s, "name": %s, "body": %s, "prerelease": %s}' \
    "$tag_json" "$name_json" "$body_json" "$prerelease_value")

  RELEASE_RESPONSE=$(curl -sS --fail-with-body -X POST \
    -H "Authorization: token ${GITHUB_TOKEN}" \
    -H "Content-Type: application/json" \
    -d "${payload}" \
    "${api_url}" 2>&1)
  curl_status=$?

  release_id=$(echo "$RELEASE_RESPONSE" | jq -r '.id // empty' 2>/dev/null)
  api_error_message=$(echo "$RELEASE_RESPONSE" | jq -r '.message // empty' 2>/dev/null)

  if [ $curl_status -ne 0 ]; then
    printError "Error executing curl command for creating release tag: $tag"
    if [ -n "$api_error_message" ]; then
      printError "GitHub API Error: $api_error_message"
    fi
    printError "Full GitHub API response:"
    printError "$RELEASE_RESPONSE"
    return 1
  fi

  if [ -z "$release_id" ]; then
    printError "Error creating GitHub release tag: $tag"
    if [ -n "$api_error_message" ]; then
      printError "GitHub API Error: $api_error_message"
    fi
    printError "Full GitHub API response:"
    printError "$RELEASE_RESPONSE"
    return 1
  fi

  if ! validateReleaseId "$release_id"; then
    printError "Full GitHub API response:"
    printError "$RELEASE_RESPONSE"
    return 1
  fi

  printVerbose "GitHub release created successfully. Release ID: $release_id, Latest: ${make_latest_release}"

  # Machine-readable return value only.
  echo "$release_id"
  return 0
}

uploadGitHubReleaseAsset() {
  release_id="$1"
  asset_file="$2"
  asset_name=$(basename "$asset_file")

  if ! validateReleaseId "$release_id"; then
    return 1
  fi

  if [ ! -f "$asset_file" ]; then
    printError "Asset file not found: $asset_file"
    return 1
  fi

  printVerbose "Uploading asset: $asset_file to release ID: $release_id"

  asset_name_encoded=$(printf '%s' "$asset_name" | jq -sRr @uri)
  upload_url=$(printf "https://uploads.github.com/repos/%s/%s/releases/%s/assets?name=%s" \
    "${GITHUB_ORGANIZATION}" "${GITHUB_REPO}" "$release_id" "$asset_name_encoded")

  content_length=$(wc -c < "$asset_file" | tr -d ' ')
  printVerbose "Content-Length: ${content_length}"
  printVerbose "Upload URL: ${upload_url}"

  ASSET_UPLOAD_RESPONSE=$(curl -sS --fail-with-body --progress-bar -X POST \
    -H "Authorization: token ${GITHUB_TOKEN}" \
    -H "Content-Type: application/octet-stream" \
    --data-binary "@${asset_file}" \
    "$upload_url" 2>&1)
  curl_status=$?

  asset_state=$(echo "$ASSET_UPLOAD_RESPONSE" | jq -r '.state // empty' 2>/dev/null)
  api_error_message=$(echo "$ASSET_UPLOAD_RESPONSE" | jq -r '.message // empty' 2>/dev/null)

  if [ $curl_status -ne 0 ]; then
    printError "Error uploading asset: $asset_file to release ID: $release_id"
    if [ -n "$api_error_message" ]; then
      printError "GitHub API Error: $api_error_message"
    fi
    printError "Full curl/GitHub output:"
    printError "$ASSET_UPLOAD_RESPONSE"
    return 1
  fi

  if [ -z "$asset_state" ] || [ "$asset_state" != "uploaded" ]; then
    printError "Asset upload did not complete successfully: $asset_file"
    if [ -n "$api_error_message" ]; then
      printError "GitHub API Error: $api_error_message"
    fi
    printError "Full GitHub API response:"
    printError "$ASSET_UPLOAD_RESPONSE"
    return 1
  fi

  printVerbose "Asset uploaded successfully: $asset_file to release ID: $release_id"
  return 0
}

deleteGitHubReleaseByTag() {
  tag="$1"

  printVerbose "Checking for existing release tag: $tag"

  release_api_url="https://api.github.com/repos/${GITHUB_ORGANIZATION}/${GITHUB_REPO}/releases/tags/${tag}"

  RELEASE_INFO_RESPONSE=$(curl -sS \
    -H "Authorization: token ${GITHUB_TOKEN}" \
    "$release_api_url" 2>&1)
  curl_status=$?

  release_id=$(echo "$RELEASE_INFO_RESPONSE" | jq -r '.id // empty' 2>/dev/null)
  api_error_message=$(echo "$RELEASE_INFO_RESPONSE" | jq -r '.message // empty' 2>/dev/null)

  if [ $curl_status -ne 0 ]; then
    printError "Error executing curl command for checking release tag: $tag"
    printError "$RELEASE_INFO_RESPONSE"
    return 1
  fi

  if [ -z "$release_id" ]; then
    printVerbose "No existing release found for tag: $tag. GitHub message: ${api_error_message}"
    return 0
  fi

  if ! validateReleaseId "$release_id"; then
    printError "Invalid release ID received while checking tag: $tag"
    printError "$RELEASE_INFO_RESPONSE"
    return 1
  fi

  printVerbose "Found existing release ID: $release_id for tag: $tag"
  printVerbose "Attempting to delete existing release with tag: $tag, ID: $release_id"

  delete_api_url="https://api.github.com/repos/${GITHUB_ORGANIZATION}/${GITHUB_REPO}/releases/${release_id}"

  DELETE_RESPONSE=$(curl -sS --fail-with-body -X DELETE \
    -H "Authorization: token ${GITHUB_TOKEN}" \
    "$delete_api_url" 2>&1)
  curl_status=$?

  delete_api_error_message=$(echo "$DELETE_RESPONSE" | jq -r '.message // empty' 2>/dev/null)

  if [ $curl_status -ne 0 ]; then
    printError "Error deleting GitHub release ID: $release_id for tag: $tag"
    if [ -n "$delete_api_error_message" ]; then
      printError "GitHub API Error: $delete_api_error_message"
    fi
    printError "Full GitHub API response:"
    printError "$DELETE_RESPONSE"
    return 1
  fi

  printVerbose "GitHub release ID: $release_id for tag: $tag deleted successfully"
  return 0
}

uploadToPulp() {
  rpm_file="$1"
  build_line="$2"

  if [ -z "$PULP_BASE_ADDR" ]; then
    export PULP_BASE_ADDR="https://repo.zopen.community"
    printVerbose "PULP_BASE_ADDR not set; defaulting to $PULP_BASE_ADDR"
  fi

  if [ -n "$CUSTOM_PULP_REPO" ]; then
    PULP_REPO="$CUSTOM_PULP_REPO"
  elif [ "$build_line" = "STABLE" ]; then
    PULP_REPO="zopen-stable"
  else
    PULP_REPO="zopen-dev"
  fi

  printInfo "- Pushing $rpm_file to Pulp repository: $PULP_REPO"

  if ! pulp rpm repository upload --name "$PULP_REPO" --file "$rpm_file"; then
    printError "Failed to push RPM to Pulp repository: $PULP_REPO"
    return 1
  fi

  printVerbose "Successfully pushed $rpm_file to Pulp repository: $PULP_REPO"

  DIST_NAME="$PULP_REPO"

  printInfo "- Updating Pulp distribution $DIST_NAME"

  LATEST_PUB=$(pulp rpm publication list --repository "${PULP_REPO}" --limit 1 | jq -r '.[0].pulp_href // empty')
  if [ -n "$LATEST_PUB" ]; then
    if ! pulp rpm distribution update --name "${DIST_NAME}" --publication "${LATEST_PUB}" > /dev/null; then
      printWarning "Warning: Failed to update Pulp distribution ${DIST_NAME}"
    fi
  else
    printWarning "Warning: Could not find latest publication for ${PULP_REPO}"
  fi

  return 0
}

publishRelease() {
  PAX_BASENAME=$(basename "${PAX_FILE}")
  VERSION=$(jq -r '.product.version // empty' "$METADATA_FILE")

  if [ -z "$VERSION" ]; then
    printError "Error: product.version not found in metadata.json"
    return 1
  fi

  METADATA_REPO_URL=$(jq -r '.product.repo // empty' "$METADATA_FILE")
  if [ -z "$METADATA_REPO_URL" ]; then
    printError "Error: Repository URL product.repo not found in metadata.json"
    return 1
  fi

  if [ -n "$PORT_GITHUB_REPO_OPT" ]; then
    PORT_GITHUB_REPO="$PORT_GITHUB_REPO_OPT"
    printVerbose "Using repository URL from command line option: $PORT_GITHUB_REPO"
  else
    PORT_GITHUB_REPO="$METADATA_REPO_URL"
    printVerbose "Using repository URL from metadata.json: $PORT_GITHUB_REPO"
  fi

  RELEASE_PREFIX=$(basename "${PORT_GITHUB_REPO}")
  RELEASE_PREFIX=${RELEASE_PREFIX%%.git}
  RELEASE_PREFIX=${RELEASE_PREFIX%%.*}
  PORT_NAME=${RELEASE_PREFIX%%port}
  GITHUB_REPO=$RELEASE_PREFIX

  if [ -z "$GITHUB_REPO" ]; then
    printError "Error: Could not determine GitHub repository name from: $PORT_GITHUB_REPO"
    return 1
  fi

  if [ -z "$PORT_NAME" ]; then
    printError "Error: Could not determine port name from repository: $GITHUB_REPO"
    return 1
  fi

  if [ -z "$PORT_DESCRIPTION_OPT" ]; then
    PORT_DESCRIPTION=$(jq -r '.product.summary // empty' "$METADATA_FILE")
    if [ -z "$PORT_DESCRIPTION" ]; then
      printError "Error: Description product.summary not found in metadata.json and not provided."
      return 1
    fi
    printVerbose "Using description from metadata.json: $PORT_DESCRIPTION"
  else
    PORT_DESCRIPTION="$PORT_DESCRIPTION_OPT"
    printVerbose "Using description from command line option: $PORT_DESCRIPTION"
  fi

  if [ -z "$BUILD_LINE_OPT" ]; then
    BUILD_LINE=$(jq -r '.product.buildline // empty' "$METADATA_FILE")
    BUILD_LINE_UPPER=$(echo "$BUILD_LINE" | tr '[:lower:]' '[:upper:]')
    if [ "$BUILD_LINE_UPPER" != "DEV" ] && [ "$BUILD_LINE_UPPER" != "STABLE" ]; then
      printError "Error: Invalid build line in metadata.json: $BUILD_LINE. Must be DEV or STABLE."
      return 1
    fi
    BUILD_LINE="$BUILD_LINE_UPPER"
    printVerbose "Using build line from metadata.json: $BUILD_LINE"
  else
    BUILD_LINE="$BUILD_LINE_OPT"
    BUILD_LINE_UPPER=$(echo "$BUILD_LINE" | tr '[:lower:]' '[:upper:]')
    if [ "$BUILD_LINE_UPPER" != "DEV" ] && [ "$BUILD_LINE_UPPER" != "STABLE" ]; then
      printError "Invalid build line: $BUILD_LINE. Must be DEV or STABLE."
      printSyntax
      return 1
    fi
    BUILD_LINE="$BUILD_LINE_UPPER"
    printVerbose "Using build line from command line option: $BUILD_LINE"
  fi

  TAG="${RELEASE_TAG_OPT}"
  NAME="${PORT_NAME} ${VERSION} (${TAG}) - (${BUILD_LINE})"

  DESCRIPTION="${PORT_DESCRIPTION}<br />"
  DESCRIPTION="${DESCRIPTION}<b>Version:</b> ${VERSION}<br />"
  URL_LINE="https://github.com/${GITHUB_ORGANIZATION}/${GITHUB_REPO}/releases/download/${TAG}/${PAX_BASENAME}"
  DESCRIPTION="${DESCRIPTION}<br /><b>Command to download and install on z/OS if you have curl</b> <pre>curl -o ${PAX_BASENAME} -L ${URL_LINE} && pax -rf ${PAX_BASENAME} && cd ${PORT_NAME} && . ./setup.sh</pre>"
  DESCRIPTION="${DESCRIPTION}<br /><b>Or use:</b> <pre>zopen install ${PORT_NAME}</pre>"

  if ${FORCE_OVERWRITE}; then
    if ! deleteGitHubReleaseByTag "${TAG}"; then
      printWarning "Warning: Deleting existing release tag '${TAG}' failed, but force overwrite is enabled. Proceeding with release creation."
    fi
  else
    if ! deleteGitHubReleaseByTag "${TAG}"; then
      printError "Error: Checking/deleting existing release tag '${TAG}' failed. Use --force only if you want to proceed anyway."
      return 1
    fi
    printVerbose "Existing release tag '${TAG}' deleted successfully or no existing release found."
  fi

  RELEASE_ID=$(createGitHubRelease "${TAG}" "${NAME}" "${DESCRIPTION}" "${MAKE_LATEST_RELEASE}")
  rc=$?

  if [ $rc -ne 0 ]; then
    return 1
  fi

  if ! validateReleaseId "$RELEASE_ID"; then
    return 1
  fi

  if ! uploadGitHubReleaseAsset "${RELEASE_ID}" "${PAX_FILE}"; then
    return 1
  fi

  if ! uploadGitHubReleaseAsset "${RELEASE_ID}" "${METADATA_FILE}"; then
    return 1
  fi

  if [ "$PUSH_TO_PULP" = true ]; then
    RPM_COUNT=0
    RPM_DIRS="rpmbuild/RPMS"

    if [ -d "$RPM_DIRS" ]; then
      for rpm_file in "$RPM_DIRS"/*.rpm; do
        if [ -f "$rpm_file" ]; then
          if ! uploadToPulp "$rpm_file" "$BUILD_LINE"; then
            return 1
          fi
          RPM_COUNT=$((RPM_COUNT + 1))
        fi
      done
    fi

    if [ $RPM_COUNT -eq 0 ]; then
      PAX_DIR=$(dirname "$PAX_FILE")
      for rpm_file in "$PAX_DIR"/*.rpm; do
        if [ -f "$rpm_file" ]; then
          if ! uploadToPulp "$rpm_file" "$BUILD_LINE"; then
            return 1
          fi
          RPM_COUNT=$((RPM_COUNT + 1))
        fi
      done
    fi

    if [ $RPM_COUNT -gt 0 ]; then
      printInfo "- Found $RPM_COUNT RPM(s) pushed to Pulp."
    else
      printWarning "Pulp push requested, but no RPM files were found."
    fi
  fi

  echo "Release published successfully to https://github.com/${GITHUB_ORGANIZATION}/${GITHUB_REPO}/releases/tag/${TAG}"
  return 0
}

publishToPulp() {
  whl_basename=$(basename "${WHL_FILE}")

  pulp_upload_url="${PULP_URL%/}"
  case "$pulp_upload_url" in
    */legacy)
      pulp_upload_url="${pulp_upload_url}/"
      ;;
    */legacy/)
      ;;
    *)
      pulp_upload_url="${pulp_upload_url}/legacy/"
      ;;
  esac

  printInfo "Uploading ${whl_basename} to ${pulp_upload_url}"

  UPLOAD_RESPONSE=$(curl -sS -w "\n%{http_code}" \
    -u "${PULP_USER}:${PULP_PASSWORD}" \
    -F "content=@${WHL_FILE}" \
    -F ":action=file_upload" \
    -F "filetype=bdist_wheel" \
    "${pulp_upload_url}" 2>&1)

  http_code=$(echo "$UPLOAD_RESPONSE" | tail -1)
  response_body=$(echo "$UPLOAD_RESPONSE" | sed '$d')

  if [ "$http_code" != "200" ] && [ "$http_code" != "201" ]; then
    printSoftError "Pulp upload failed with HTTP ${http_code}"
    printSoftError "Response: ${response_body}"
    return 1
  fi

  task_url=$(echo "$response_body" | jq -r '.task // empty' 2>/dev/null)

  if [ -n "$task_url" ]; then
    printVerbose "Pulp task created: ${task_url}"

    pulp_base_url="${PULP_URL%/pypi*}"
    task_full_url="${pulp_base_url}${task_url}"

    printVerbose "Checking task status at: ${task_full_url}"

    retries=0
    while [ $retries -lt 30 ]; do
      task_response=$(curl -sS -u "${PULP_USER}:${PULP_PASSWORD}" "${task_full_url}" 2>&1)
      task_state=$(echo "$task_response" | jq -r '.state // empty' 2>/dev/null)

      case "$task_state" in
        completed)
          printInfo "Wheel ${whl_basename} published to Pulp successfully."
          return 0
          ;;

        failed)
          task_error=$(echo "$task_response" | jq -r '.error.description // empty' 2>/dev/null)
          printSoftError "Pulp task failed: ${task_error}"
          return 1
          ;;

        canceled)
          printSoftError "Pulp task was canceled."
          return 1
          ;;
      esac

      retries=$((retries + 1))
      sleep 2
    done

    printSoftError "Pulp task did not complete within 60 seconds."
    return 1
  fi

  printInfo "Wheel ${whl_basename} published to Pulp successfully."
  return 0
}

# --- Main Script ---

GITHUB_ORGANIZATION="zopencommunity"
PAX_FILE=""
METADATA_FILE=""
PORT_GITHUB_REPO=""
PORT_GITHUB_REPO_OPT=""
PORT_DESCRIPTION=""
PORT_DESCRIPTION_OPT=""
BUILD_LINE=""
BUILD_LINE_OPT=""
GITHUB_TOKEN_OPT=""
MAKE_LATEST_RELEASE=false
RELEASE_TAG_OPT=""
FORCE_OVERWRITE=false
WHL_FILE=""
PULP_URL_OPT=""
PULP_USER_OPT=""
PULP_PASSWORD_OPT=""
PUBLISH_GITHUB=false
PUBLISH_PULP=false
PUSH_TO_PULP=false
CUSTOM_PULP_REPO=""
verbose=false

processOptions "$@"

if checkDependencies; then
  printVerbose "Dependencies check passed."
else
  printError "Some dependencies are missing. Please install them and try again."
  exit 1
fi

publish_failed=false

if ${PUBLISH_GITHUB}; then
  if publishRelease; then
    echo "GitHub publish completed successfully."
  else
    printSoftError "GitHub publish failed."
    publish_failed=true
  fi
fi

if ${PUBLISH_PULP}; then
  if publishToPulp; then
    echo "Pulp publish completed successfully."
  else
    printSoftError "Pulp publish failed."
    publish_failed=true
  fi
fi

if ${publish_failed}; then
  printError "zopen-publish completed with errors."
  exit 1
fi

echo "zopen-publish completed successfully."
exit 0
